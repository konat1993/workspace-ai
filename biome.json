{
    "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**",
            "!node_modules",
            "!.next",
            "!dist",
            "!build",
            "!.cspell.json"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "noUnusedImports": {
                    "level": "error",
                    "fix": "safe"
                }
            },
            "suspicious": {
                "noUnknownAtRules": "off",
                "useAwait": "error",
                "noConsole": {
                    "level": "error",
                    "options": {
                        "allow": ["info", "error", "warn"]
                    }
                }
            },
            "style": {
                "noUnusedTemplateLiteral": "error",
                "useConsistentCurlyBraces": {
                    "level": "error",
                    "fix": "safe"
                },
                "useTemplate": {
                    "level": "error",
                    "fix": "safe"
                }
            },
            "complexity": {
                "noUselessFragments": {
                    "level": "error",
                    "fix": "safe"
                },
                "noUselessStringConcat": "error",
                "useLiteralKeys": {
                    "level": "error",
                    "fix": "safe"
                }
            },
            "nursery": {
                "useMaxParams": {
                    "level": "error",
                    "options": { "max": 2 }
                }
            }
        },
        "domains": {
            "next": "recommended",
            "react": "recommended"
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}

{
	"version": "0.2",
	"language": "en,pl",
	"useGitignore": true,
	"dictionaries": [
		"pl_pl",
		"softwareTerms",
		"node",
		"typescript",
		"html"
	],
	"ignorePaths": [
		"node_modules",
		".next",
		"out",
		"dist",
		"build",
		"coverage",
		".git",
		".cursor",
		".vercel",
		".turbo/**",
		"pnpm-lock.yaml",
		"package-lock.json",
		"yarn.lock",
		"bun.lock",
		"public/**",
		"src/generated/**",
		"prisma/migrations/**",
		".env",
		".env.*",
		"*.tsbuildinfo",
		"next-env.d.ts"
	],
	"words": [
		"cmdk",
		"DMMF",
		"Embla",
		"logomark",
		"nums",
		"shadcn",
		"vaul",
		"vercel"
	],
	"files": [
		"**/*.ts",
		"**/*.tsx",
		"**/*.js",
		"**/*.jsx",
		"**/*.mjs",
		"**/*.cjs",
		"**/*.css",
		"**/*.md",
		"**/*.json",
		"**/*.prisma",
		"**/*.yml",
		"**/*.yaml",
		"**/*.toml"
	]
}
